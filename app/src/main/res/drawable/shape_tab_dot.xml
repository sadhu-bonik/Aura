<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- outer translucent glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#44FF3B30" />
        </shape>
    </item>
    <!-- inner solid red dot -->
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#FF3B30" />
        </shape>
    </item>
</layer-list>
