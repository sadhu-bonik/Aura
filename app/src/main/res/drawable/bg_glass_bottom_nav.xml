<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF0F0E12" />
            <corners
                android:topLeftRadius="@dimen/bottom_nav_corner_radius"
                android:topRightRadius="@dimen/bottom_nav_corner_radius"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#2927252D"
                android:endColor="#00000000" />
            <corners
                android:topLeftRadius="@dimen/bottom_nav_corner_radius"
                android:topRightRadius="@dimen/bottom_nav_corner_radius"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
