<?xml version="1.0" encoding="utf-8"?>
<!--
    Brand Registration - Step 2: Brand Identity
    Design ref: brand_brand_identity_2_5/screen.png
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B20B1326"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_app_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg">

            <ImageView
                android:id="@+id/iv_close"
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/colorOnSurface"
                android:contentDescription="@string/cd_back_button"
                android:layout_marginEnd="@dimen/space_md" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/login_title"
                android:textColor="@color/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Onboarding"
                android:textColor="@color/colorOnSurface"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:alpha="0.6" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_lg">

            <!-- Step header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/space_md">

                <TextView
                    android:id="@+id/tv_step_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_reg_step2_tag"
                    android:textColor="@color/colorTertiary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_step_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_reg_step2_title"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_reg_step2_subtitle"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="@dimen/space_xl" />
            </LinearLayout>

            <!-- Logo upload section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_surface"
                android:padding="@dimen/space_lg"
                android:gravity="center_horizontal"
                android:layout_marginBottom="@dimen/space_md">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_reg_logo_label"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/space_lg" />

                <!-- Circular logo upload zone -->
                <FrameLayout
                    android:id="@+id/layout_logo_upload"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@color/colorSurfaceContainerHighest"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="@dimen/space_md">

                    <LinearLayout
                        android:id="@+id/layout_logo_prompt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:layout_width="@dimen/icon_size_xl"
                            android:layout_height="@dimen/icon_size_xl"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="@color/colorOnSurfaceVariant"
                            android:layout_marginBottom="@dimen/space_sm"
                            android:contentDescription="@string/cd_upload_photo" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/brand_reg_upload_logo_label"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_logo_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@string/cd_upload_photo" />
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_reg_logo_spec"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- Editorial Tip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_surface"
                android:padding="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_sm">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="@color/colorTertiary"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_editorial_tip_title"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_reg_editorial_tip_body"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Core Identity fields section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Core Identity"
                android:textColor="@color/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/space_lg" />

            <!-- Motto -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_motto_label"
                android:textColor="@color/colorOnSurface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_motto"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_motto"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/brand_reg_motto_hint"
                    android:inputType="text"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Bio -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_bio_label"
                android:textColor="@color/colorOnSurface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_bio"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="5"
                    android:hint="@string/brand_reg_bio_hint"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_bio_char_limit"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:gravity="end"
                android:layout_marginBottom="@dimen/space_lg" />

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/layout_bottom_nav"
        layout="@layout/component_reg_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
