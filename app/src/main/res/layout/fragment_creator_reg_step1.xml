<?xml version="1.0" encoding="utf-8"?>
<!--
    Creator Registration - Step 1: Create Account
    Design ref: create_account_step_1_4/screen.png
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B20B1326"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_app_bar_height"
            app:navigationIcon="@android:drawable/ic_media_previous"
            app:navigationIconTint="@color/colorPrimary"
            app:title="@string/creator_onboarding_title"
            app:titleTextColor="@color/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable form content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_lg">

            <!-- Progress Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/space_xl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_md">

                    <ProgressBar
                        android:id="@+id/pb_video_1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        android:visibility="gone"
                        android:indeterminateTint="@color/colorPrimary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_step_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/creator_reg_step1_label"
                            android:textColor="@color/colorTertiary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_step_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/creator_reg_step1_title"
                            android:textColor="@color/colorOnSurface"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_step_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/creator_reg_step1_tag"
                        android:textColor="@color/colorSecondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Progress bar – 25% for step 1 of 4 -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_bar"
                    style="@style/Widget.Aura.ProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="25"
                    app:trackCornerRadius="4dp" />
            </LinearLayout>

            <!-- Form start -->

            <!-- Full Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_full_name_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_full_name"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/creator_reg_full_name_hint"
                    android:inputType="textPersonName"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_email_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/creator_reg_email_hint"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password and confirm (side by side on large screens, stacked on small) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_password_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_sm"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_password_hint"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="11sp"
                android:layout_marginBottom="@dimen/space_lg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_confirm_password_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_confirm_password"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_phone_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="@dimen/space_sm" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_lg">

                <TextView
                    android:id="@+id/tv_phone_prefix"
                    android:layout_width="64dp"
                    android:layout_height="@dimen/input_height"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center"
                    android:text="@string/creator_reg_phone_prefix"
                    android:textColor="@color/colorOnSurface"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginEnd="@dimen/space_sm" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_phone"
                    style="@style/Widget.Aura.TextInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/creator_reg_phone_hint"
                        android:inputType="phone"
                        android:textColor="@color/colorOnSurface" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Security Question -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_security_question_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_security_question"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                app:boxBackgroundColor="@color/colorSurfaceContainerHighest"
                app:boxStrokeWidth="0dp">

                <AutoCompleteTextView
                    android:id="@+id/acv_security_question"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="none"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Security Answer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_security_answer_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="@dimen/space_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_security_answer"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_security_answer"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/creator_reg_security_answer_hint"
                    android:inputType="text"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Cancel link -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.Aura.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creator_reg_cancel_link"
                android:textColor="@color/colorOutline" />

        </LinearLayout>
    </ScrollView>

    <!-- Fixed bottom nav bar -->
    <include
        android:id="@+id/layout_bottom_nav"
        layout="@layout/component_reg_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
