<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_md"
        android:paddingBottom="100dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UI Component Gallery"
            style="@style/TextAppearance.Aura.HeadlineMedium"
            android:layout_marginBottom="@dimen/space_xl"/>

        <!-- Section Header Include -->
        <include
            android:id="@+id/inc_section_header"
            layout="@layout/include_section_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"/>

        <!-- Stat Pill Include -->
        <include
            android:id="@+id/inc_stat_pill"
            layout="@layout/include_stat_pill"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"/>

        <!-- Creator Card Horizontal Include -->
        <include
            android:id="@+id/inc_creator_card"
            layout="@layout/item_creator_card_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"/>

        <!-- Post Thumb Include -->
        <include
            android:id="@+id/inc_post_thumb"
            layout="@layout/item_post_thumb"
            android:layout_width="100dp"
            android:layout_height="133dp"
            android:layout_marginBottom="@dimen/space_xl"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="State Layouts"
            style="@style/TextAppearance.Aura.TitleMedium"
            android:layout_marginBottom="@dimen/space_md"/>

        <!-- Loading Include -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="@dimen/space_md"
            android:background="@color/colorSurfaceContainerLow">
            <include layout="@layout/layout_loading" />
        </FrameLayout>

        <!-- Empty State Include -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="@dimen/space_md"
            android:background="@color/colorSurfaceContainerLow">
            <include layout="@layout/layout_empty_state" />
        </FrameLayout>

        <!-- Error Layout Include -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="@dimen/space_xl"
            android:background="@color/colorSurfaceContainerLow">
            <include layout="@layout/layout_error" />
        </FrameLayout>

    </LinearLayout>
</ScrollView>
