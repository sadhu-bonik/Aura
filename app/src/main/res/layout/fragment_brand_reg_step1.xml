<?xml version="1.0" encoding="utf-8"?>
<!--
    Brand Registration - Step 1: Create Brand Account
    Design ref: brand_create_account_1_5/screen.png
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top App Bar with progress bar underneath -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B20B1326"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/top_app_bar_height"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg">

                <ImageView
                    android:id="@+id/iv_nav_back"
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="@color/colorOnSurfaceVariant"
                    android:contentDescription="@string/cd_back_button"
                    android:layout_marginEnd="@dimen/space_md" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/brand_reg_step1_tag"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"
                    android:layout_marginEnd="@dimen/space_md" />

                <ImageView
                    android:id="@+id/iv_close"
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="@color/colorOnSurfaceVariant"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Progress bar -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                style="@style/Widget.Aura.ProgressBar"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:progress="20" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingTop="@dimen/space_xl"
            android:paddingBottom="120dp">

            <!-- Secure Onboarding Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:padding="@dimen/space_md"
                android:background="@drawable/bg_banner_primary_left"
                android:layout_marginBottom="@dimen/space_xl">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@color/colorPrimaryContainer"
                    android:layout_marginEnd="@dimen/space_md">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_lock_lock"
                        android:tint="@color/colorPrimary"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_secure_banner_title"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_secure_banner_body"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tv_form_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_step1_title"
                android:textColor="@color/colorOnSurface"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="@dimen/space_sm" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_step1_subtitle"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:layout_marginBottom="@dimen/space_xl" />

            <!-- Brand Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_name_label"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginBottom="@dimen/space_xs"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_brand_name"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_brand_name"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/brand_reg_name_hint"
                    android:inputType="textCapWords"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Company Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_email_label"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginBottom="@dimen/space_xs"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/brand_reg_email_hint"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_phone_label"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginBottom="@dimen/space_xs"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_phone"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/brand_reg_phone_hint"
                    android:inputType="phone"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password pair -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_md">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/space_sm">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_password_label"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        android:layout_marginBottom="@dimen/space_xs"
                        android:layout_marginStart="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_password"
                        style="@style/Widget.Aura.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="@color/colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_confirm_password_label"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        android:layout_marginBottom="@dimen/space_xs"
                        android:layout_marginStart="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_confirm_password"
                        style="@style/Widget.Aura.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="@color/colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Password requirements chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="@dimen/space_lg">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:tint="@color/colorPrimary"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_password_req_length"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="@dimen/space_lg">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/radiobutton_off_background"
                        android:tint="@color/colorOutlineVariant"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_password_req_uppercase"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/radiobutton_off_background"
                        android:tint="@color/colorOutlineVariant"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_reg_password_req_number"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorOutlineVariant"
                android:alpha="0.3"
                android:layout_marginBottom="@dimen/space_lg" />

            <!-- Security Question -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_security_question_label"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginBottom="@dimen/space_xs"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_security_question"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                app:boxBackgroundColor="@color/colorSurfaceContainerHighest"
                app:boxStrokeWidth="0dp">

                <AutoCompleteTextView
                    android:id="@+id/acv_security_question"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="none"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Security Answer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_security_answer_label"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginBottom="@dimen/space_xs"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_security_answer"
                style="@style/Widget.Aura.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_xl">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_security_answer"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/brand_reg_security_answer_hint"
                    android:inputType="text"
                    android:textColor="@color/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Actions (stacked on mobile) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/brand_reg_next_btn"
                    android:textColor="@color/colorOnPrimary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:background="@drawable/bg_button_primary_gradient"
                    app:cornerRadius="26dp"
                    android:layout_marginBottom="@dimen/space_sm" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back"
                    style="@style/Widget.Aura.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/nav_btn_back" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
