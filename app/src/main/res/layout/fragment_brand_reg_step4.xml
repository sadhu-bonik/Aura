<?xml version="1.0" encoding="utf-8"?>
<!--
    Brand Registration - Step 4: Market Presence (Industry Tags + Target Location)
    Design ref: brand_brand_details_3_4/screen.png
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B20B1326"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_app_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg">

            <ImageView
                android:id="@+id/iv_close"
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/colorPrimary"
                android:contentDescription="@string/cd_back_button"
                android:layout_marginEnd="@dimen/space_md" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Onboarding"
                android:textColor="@color/colorOnSurface"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:alpha="0.6" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingTop="@dimen/space_xl"
            android:paddingBottom="@dimen/space_xl">

            <!-- Progress bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/space_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/brand_reg_step4_tag"
                    android:textColor="@color/colorSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75% Complete"
                    android:textColor="@color/colorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                style="@style/Widget.Aura.ProgressBar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progress="80"
                android:layout_marginBottom="@dimen/space_xl" />

            <!-- Headline -->
            <TextView
                android:id="@+id/tv_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_step4_title"
                android:textColor="@color/colorOnSurface"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="@dimen/space_sm" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_step4_subtitle"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="@dimen/space_xxl" />

            <!-- Industry Tags section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_industry_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="@dimen/space_lg" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_industries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_xxl"
                app:singleSelection="false">
                <!-- Chips populated programmatically from CreatorNicheTags.NICHE_TAGS -->
            </com.google.android.material.chip.ChipGroup>

            <!-- Target Location section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/brand_reg_location_label"
                android:textColor="@color/colorSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="@dimen/space_md" />

            <!-- City -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="@dimen/space_sm">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="@color/colorOutline"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:contentDescription="@null" />

                <EditText
                    android:id="@+id/et_city"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/brand_reg_city_hint"
                    android:textColor="@color/colorOnSurface"
                    android:textColorHint="@color/colorOutline"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Region/State + Country (horizontal) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginEnd="@dimen/space_sm">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@android:drawable/ic_menu_mapmode"
                        android:tint="@color/colorOutline"
                        android:layout_marginStart="@dimen/space_md"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/et_state"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/input_height"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/brand_reg_state_hint"
                        android:textColor="@color/colorOnSurface"
                        android:textColorHint="@color/colorOutline"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@android:drawable/ic_menu_compass"
                        android:tint="@color/colorOutline"
                        android:layout_marginStart="@dimen/space_md"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/et_country"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/input_height"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/brand_reg_country_hint"
                        android:textColor="@color/colorOnSurface"
                        android:textColorHint="@color/colorOutline"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/layout_bottom_nav"
        layout="@layout/component_reg_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
