<?xml version="1.0" encoding="utf-8"?>
<!--
    Creator Registration - Step 3: Creator Details (Niches / Location / Audience)
    Design ref: creator_details_step_3_4/screen.png
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B20B1326"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_app_bar_height"
            app:navigationIcon="@android:drawable/ic_media_previous"
            app:navigationIconTint="@color/colorPrimary"
            app:title="@string/creator_onboarding_title"
            app:titleTextColor="@color/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_lg">

            <!-- Step header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/space_xl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_step_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/creator_reg_step3_tag"
                            android:textColor="@color/colorTertiary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_step_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/creator_reg_step3_title"
                            android:textColor="@color/colorOnSurface"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_bar"
                    style="@style/Widget.Aura.ProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="75" />
            </LinearLayout>

            <!-- Niches section card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg"
                android:background="@drawable/bg_card_surface"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_sm">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:tint="@color/colorPrimary"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/creator_reg_niche_title"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/creator_reg_niche_desc"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="@dimen/space_lg" />

                <!-- Niche chip buttons (flow layout via wrapping LinearLayout) -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_niches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tech"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tech"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_fitness"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fitness" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_beauty"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beauty" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_gaming"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gaming"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_travel"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Travel" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_fashion"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fashion" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_food"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Food" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_lifestyle"
                        style="@style/Widget.Aura.Chip.Niche"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lifestyle" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- Location section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg"
                android:background="@drawable/bg_card_surface"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@android:drawable/ic_menu_mylocation"
                        android:tint="@color/colorPrimary"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/creator_reg_location_title"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/creator_reg_city_label"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/space_sm" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_city"
                    style="@style/Widget.Aura.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_city"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/creator_reg_city_hint"
                        android:textColor="@color/colorOnSurface" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="@dimen/space_sm">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/creator_reg_state_label"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="@dimen/space_sm" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_state"
                            style="@style/Widget.Aura.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_state"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:hint="@string/creator_reg_state_hint"
                                android:textColor="@color/colorOnSurface" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/creator_reg_country_label"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="@dimen/space_sm" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_country"
                            style="@style/Widget.Aura.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_country"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:hint="@string/creator_reg_country_hint"
                                android:textColor="@color/colorOnSurface" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Audience section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg"
                android:background="@drawable/bg_card_surface"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_md">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@android:drawable/ic_menu_compass"
                        android:tint="@color/colorTertiary"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/creator_reg_audience_title"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/creator_reg_audience_label"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/space_sm" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_audience_region"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="@color/colorSurfaceContainerHighest"
                    app:boxStrokeWidth="0dp">

                    <AutoCompleteTextView
                        android:id="@+id/acv_audience_region"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:inputType="none"
                        android:text="@string/region_north_america"
                        android:textColor="@color/colorOnSurface" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/layout_bottom_nav"
        layout="@layout/component_reg_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
