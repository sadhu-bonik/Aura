<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/space_md"
    android:paddingVertical="@dimen/space_xs">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_failed_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FF3B30"
        app:cardCornerRadius="@dimen/corner_radius_lg"
        app:cardElevation="0dp"
        app:layout_constraintWidth_default="wrap"
        app:layout_constraintWidth_percent="0.75"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="@dimen/space_sm">

            <TextView
                android:id="@+id/tv_failed_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Aura.BodyLarge"
                android:textColor="@color/colorOnPrimary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="end"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_xs">

                <TextView
                    android:id="@+id/tv_failed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Failed"
                    android:textAppearance="@style/TextAppearance.Aura.LabelSmall"
                    android:textColor="#AAFFFFFF" />

                <TextView
                    android:id="@+id/btn_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:text="Retry"
                    android:textAppearance="@style/TextAppearance.Aura.LabelSmall"
                    android:textColor="@color/colorOnPrimary"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="4dp" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
