<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- Hero header: back arrow + title + subtitle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="-8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_back_button"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/colorOnSurface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_extrabold"
            android:letterSpacing="-0.02"
            android:text="@string/title_deal_history"
            android:textColor="@color/colorOnSurface"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/subtitle_deal_history"
            android:textColor="@color/colorOnSurfaceVariant"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Pill segmented control -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_dashboard_pill_track"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/btn_pill_completed"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_history_pill_selected"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:text="@string/tab_completed_deals"
            android:textColor="@color/colorOnPrimaryContainer"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_pill_past"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:text="@string/tab_past_deals"
            android:textColor="@color/colorOnSurfaceVariant"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

</LinearLayout>
