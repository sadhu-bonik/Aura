<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- Hero header: title + subtitle on the left, action icon buttons on the right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_extrabold"
                android:letterSpacing="-0.02"
                android:text="@string/title_deal_dashboard"
                android:textColor="@color/colorOnSurface"
                android:textSize="28sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/subtitle_deal_dashboard"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_history"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_dashboard_icon_button"
            android:contentDescription="@string/content_description_history"
            android:scaleType="centerInside"
            android:src="@drawable/ic_history"
            app:tint="@color/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/btn_filter"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_dashboard_icon_button"
            android:contentDescription="@string/dashboard_action_filter"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filter_list"
            app:tint="@color/colorOnSurfaceVariant" />
    </LinearLayout>

    <!-- Bento stat grid: Active / Pending / Completed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dashboard_stat_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:letterSpacing="0.15"
                android:text="@string/dashboard_stat_active"
                android:textAllCaps="true"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="10sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_stat_active"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_extrabold"
                android:text="0"
                android:textColor="@color/colorOnSurface"
                android:textSize="40sp"
                tools:text="12" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dashboard_stat_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_stat_pending_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:letterSpacing="0.15"
                android:text="@string/dashboard_stat_pending"
                android:textAllCaps="true"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="10sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_stat_pending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_extrabold"
                android:text="0"
                android:textColor="@color/colorOnSurface"
                android:textSize="40sp"
                tools:text="08" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dashboard_stat_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:letterSpacing="0.15"
                android:text="@string/dashboard_stat_completed"
                android:textAllCaps="true"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="10sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_stat_completed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_extrabold"
                android:text="0"
                android:textColor="@color/colorOnSurface"
                android:textSize="40sp"
                tools:text="45" />
        </LinearLayout>
    </LinearLayout>

    <!-- Pill segmented control -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_dashboard_pill_track"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/btn_pill_active"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dashboard_pill_selected"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/manrope_extrabold"
            android:gravity="center"
            android:text="@string/tab_active_short"
            android:textColor="@color/colorOnPrimary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_pill_pending"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:text="@string/tab_pending_short"
            android:textColor="@color/colorOnSurfaceVariant"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

</LinearLayout>
