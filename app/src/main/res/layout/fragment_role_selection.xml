<?xml version="1.0" encoding="utf-8"?>
<!--
    Role Selection Screen
    Design ref: role_selection/screen.png
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top App Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/Widget.Aura.TopAppBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_app_bar_height"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationIcon="@android:drawable/ic_media_previous"
        app:title="@string/login_title"
        app:titleTextColor="@color/colorPrimary" />

    <!-- Content scroll -->
    <ScrollView
        android:id="@+id/scrollview_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingTop="@dimen/space_xl"
            android:paddingBottom="@dimen/space_xl">

            <!-- Headline section -->
            <TextView
                android:id="@+id/tv_join_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/role_selection_title"
                android:textColor="@color/colorOnSurface"
                android:textSize="44sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.0"
                android:layout_marginBottom="@dimen/space_sm" />

            <TextView
                android:id="@+id/tv_join_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/role_selection_subtitle"
                android:textColor="@color/colorSecondary"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="@dimen/space_xxl" />

            <!-- CREATOR card -->
            <LinearLayout
                android:id="@+id/card_creator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_xl"
                android:background="@drawable/bg_card_role_selected"
                android:layout_marginBottom="@dimen/space_lg"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@null">

                <!-- Icon row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_md">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@color/colorPrimary">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/star_big_on"
                            android:tint="@color/colorPrimary"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Selected checkmark (visible when selected) -->
                    <ImageView
                        android:id="@+id/iv_creator_check"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:tint="@color/colorPrimary"
                        android:visibility="visible"
                        android:contentDescription="@null" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_creator_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_creator_title"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView
                    android:id="@+id/tv_creator_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_creator_desc"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="@dimen/space_md" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@color/colorPrimary"
                        android:layout_marginEnd="@dimen/space_sm" />

                    <TextView
                        android:id="@+id/tv_creator_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/role_creator_tag"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12" />
                </LinearLayout>
            </LinearLayout>

            <!-- BRAND card -->
            <LinearLayout
                android:id="@+id/card_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_xl"
                android:background="@drawable/bg_card_glass"
                android:layout_marginBottom="@dimen/space_xxl"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@null">

                <!-- Icon row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_md">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@color/colorTertiaryContainer">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_manage"
                            android:tint="@color/colorTertiary"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Unselected placeholder (hidden when brand is not selected) -->
                    <ImageView
                        android:id="@+id/iv_brand_check"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:tint="@color/colorPrimary"
                        android:visibility="gone"
                        android:contentDescription="@null" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_brand_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_brand_title"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView
                    android:id="@+id/tv_brand_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_brand_desc"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="@dimen/space_md" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@color/colorTertiary"
                        android:layout_marginEnd="@dimen/space_sm" />

                    <TextView
                        android:id="@+id/tv_brand_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/role_brand_tag"
                        android:textColor="@color/colorTertiary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12" />
                </LinearLayout>
            </LinearLayout>

            <!-- Note info bar -->
            <LinearLayout
                android:id="@+id/layout_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/space_md"
                android:background="@drawable/bg_card_surface"
                android:layout_marginBottom="@dimen/space_lg">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@android:drawable/ic_dialog_info"
                    android:tint="@color/colorTertiary"
                    android:layout_marginEnd="@dimen/space_md"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_role_note"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/role_selection_note"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions bar (Continue / Back) -->
    <LinearLayout
        android:id="@+id/layout_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:paddingTop="@dimen/space_md"
        android:paddingBottom="@dimen/space_lg"
        android:background="@color/colorBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/role_selection_continue_btn"
            android:textColor="@color/colorOnPrimary"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_button_primary_gradient"
            app:cornerRadius="26dp"
            android:layout_marginBottom="@dimen/space_sm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Aura.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/role_selection_back_btn" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
