<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:padding="@dimen/space_xl">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload Portfolio Video"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:textStyle="bold"
        android:textColor="@color/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set a catchy title and describe your work natively!"
        android:layout_marginTop="@dimen/space_sm"
        android:textColor="@color/colorTextSecondary"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_video_title"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:hint="Video Title"
        app:boxCornerRadiusTopEnd="@dimen/corner_radius_sm"
        app:boxCornerRadiusTopStart="@dimen/corner_radius_sm"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_video_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:textColor="@color/colorOnSurface" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_video_description"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:hint="Short Description (Optional)"
        app:boxCornerRadiusTopEnd="@dimen/corner_radius_sm"
        app:boxCornerRadiusTopStart="@dimen/corner_radius_sm"
        app:layout_constraintTop_toBottomOf="@id/til_video_title">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_video_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:lines="4"
            android:maxLines="6"
            android:textColor="@color/colorOnSurface" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="@dimen/space_xl"
        android:layout_marginEnd="@dimen/space_sm"
        android:text="Cancel"
        android:textColor="@color/colorOnSurface"
        app:cornerRadius="@dimen/corner_radius_md"
        app:layout_constraintTop_toBottomOf="@id/til_video_description"
        app:layout_constraintEnd_toStartOf="@id/btn_upload"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_upload"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="@dimen/space_xl"
        android:layout_marginStart="@dimen/space_sm"
        android:text="Upload"
        app:cornerRadius="@dimen/corner_radius_md"
        app:layout_constraintTop_toBottomOf="@id/til_video_description"
        app:layout_constraintStart_toEndOf="@id/btn_cancel"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
