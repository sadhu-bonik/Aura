<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_md"
    android:layout_marginVertical="@dimen/space_xs"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/colorSurfaceContainer"
    app:cardCornerRadius="@dimen/corner_radius_md"
    app:cardElevation="0dp"
    app:strokeColor="@color/colorDivider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_md"
        android:paddingVertical="@dimen/space_sm">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/iv_offer_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/content_description_avatar"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Primary text -->
        <TextView
            android:id="@+id/tv_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Aura.TitleSmall"
            app:layout_constraintTop_toTopOf="@id/iv_offer_avatar"
            app:layout_constraintStart_toEndOf="@id/iv_offer_avatar"
            app:layout_constraintEnd_toStartOf="@id/iv_btn_accept" />

        <!-- Secondary text -->
        <TextView
            android:id="@+id/tv_secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_marginTop="@dimen/space_xs"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Aura.BodySmall"
            android:textColor="@color/colorTextSecondary"
            app:layout_constraintTop_toBottomOf="@id/tv_primary"
            app:layout_constraintBottom_toBottomOf="@id/iv_offer_avatar"
            app:layout_constraintStart_toEndOf="@id/iv_offer_avatar"
            app:layout_constraintEnd_toStartOf="@id/iv_btn_accept" />

        <!-- Accept button (green circle with checkmark, creator+pending only) -->
        <ImageView
            android:id="@+id/iv_btn_accept"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="@dimen/space_xs"
            android:src="@drawable/ic_check"
            android:background="@drawable/bg_accept_circle"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:contentDescription="@string/btn_accept_deal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_btn_reject" />

        <!-- Reject button (red circle with X, creator+pending only) -->
        <ImageView
            android:id="@+id/iv_btn_reject"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="@dimen/space_xs"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_reject_circle"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:contentDescription="@string/btn_reject_deal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_chevron" />

        <!-- Chevron -->
        <ImageView
            android:id="@+id/iv_chevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/content_description_chevron"
            android:src="@drawable/ic_chevron_right"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Status chip (Past deals only; hidden by default) -->
        <TextView
            android:id="@+id/tv_status_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textAppearance="@style/TextAppearance.Aura.LabelSmall"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_chevron" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
