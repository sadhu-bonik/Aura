<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    app:cardBackgroundColor="@color/colorSurfaceContainer"
    app:cardCornerRadius="@dimen/corner_radius_md"
    app:cardElevation="0dp"
    app:layout_constraintDimensionRatio="3:4"
    app:strokeWidth="0dp">

    <ImageView
        android:id="@+id/iv_post_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/cd_photo_preview"
        android:scaleType="centerCrop"
        tools:src="@color/colorSurfaceContainerHigh" />

    <FrameLayout
        android:id="@+id/play_count_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="@dimen/space_sm"
        android:background="@drawable/bg_play_count_pill"
        android:paddingHorizontal="@dimen/space_sm"
        android:paddingVertical="2dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_play_count"
            style="@style/TextAppearance.Aura.LabelMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            tools:text="42.8K" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
