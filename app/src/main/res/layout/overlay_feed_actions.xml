<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/feed_actions_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="end|center_vertical"
    android:layout_marginEnd="12dp"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <ImageButton
        android:id="@+id/btn_shortlist"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_shortlist_outline"
        android:scaleType="centerInside"
        android:contentDescription="@string/action_shortlist" />

    <TextView
        android:id="@+id/label_shortlist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_shortlist"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:layout_marginBottom="20dp" />

    <ImageButton
        android:id="@+id/btn_deal"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_deal"
        android:scaleType="centerInside"
        android:contentDescription="@string/action_deal" />

    <TextView
        android:id="@+id/label_deal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_deal"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:layout_marginBottom="20dp" />

    <ImageButton
        android:id="@+id/btn_more"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_more"
        android:scaleType="centerInside"
        android:contentDescription="@string/action_more" />
</LinearLayout>
