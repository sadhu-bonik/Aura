<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/error_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/space_xl"
    android:paddingVertical="@dimen/space_xxl">

    <ImageView
        android:id="@+id/iv_error_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:alpha="0.7"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_close"
        app:tint="@color/colorErrorDim"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_error_message"
        style="@style/TextAppearance.Aura.BodyLarge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:gravity="center"
        android:textColor="@color/colorOnSurfaceVariant"
        tools:text="Something went wrong. Please try again." />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_retry"
        style="@style/Widget.Aura.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:minWidth="160dp"
        android:text="@string/retry" />
</LinearLayout>
