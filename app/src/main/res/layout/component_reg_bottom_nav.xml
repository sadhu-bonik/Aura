<?xml version="1.0" encoding="utf-8"?>
<!-- Shared bottom navigation bar for registration step screens -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/bottom_nav_height"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingStart="@dimen/space_lg"
    android:paddingEnd="@dimen/space_lg"
    android:background="@drawable/bg_bottom_nav">

    <!-- Back -->
    <LinearLayout
        android:id="@+id/btn_nav_back"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/space_sm"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/colorOnSurface"
            android:alpha="0.6"
            android:contentDescription="@string/cd_back_button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_btn_back"
            android:textColor="@color/colorOnSurface"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:alpha="0.6" />
    </LinearLayout>

    <!-- Save & Exit -->
    <LinearLayout
        android:id="@+id/btn_nav_save_exit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/space_sm"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:src="@android:drawable/ic_menu_save"
            android:tint="@color/colorOnSurface"
            android:alpha="0.6"
            android:contentDescription="@string/nav_btn_save_exit" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_btn_save_exit"
            android:textColor="@color/colorOnSurface"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:alpha="0.6" />
    </LinearLayout>

    <!-- Next / Finish (primary CTA) -->
    <LinearLayout
        android:id="@+id/btn_nav_next"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_sm"
        android:background="@drawable/bg_button_primary_gradient"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tv_nav_next_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_btn_next"
            android:textColor="@color/colorOnPrimary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <ImageView
            android:layout_width="@dimen/icon_size_sm"
            android:layout_height="@dimen/icon_size_sm"
            android:src="@android:drawable/ic_media_next"
            android:tint="@color/colorOnPrimary"
            android:layout_marginStart="@dimen/space_sm"
            android:contentDescription="@null" />
    </LinearLayout>

</LinearLayout>
